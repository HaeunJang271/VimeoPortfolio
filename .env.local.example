# Firebase Client (브라우저 — Vercel에도 동일하게 등록 후 재배포 필수)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_SITE_NAME=MAKMALLO

# Firebase Admin (서버 전용 — 로컬만)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase Admin (Vercel 필수 — JSON 전체를 한 줄로 붙여넣기)
# Vercel에는 FIREBASE_SERVICE_ACCOUNT_PATH 를 넣지 마세요 (파일이 없어 빌드 실패)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# 선택: Firestore admins 대신 이메일로 어드민 허용 (쉼표 구분)
# ADMIN_EMAILS=admin@example.com
