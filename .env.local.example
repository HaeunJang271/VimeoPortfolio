# Firebase Client (브라우저 — Vercel에도 동일하게 등록 후 재배포 필수)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_SITE_NAME=MAKMALLO

# 링크 공유 미리보기(OG)용 사이트 URL — Production 도메인
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Firebase Admin (서버 전용 — 로컬만)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase Admin (Vercel 권장 — JSON 한 줄, 가장 안정적)
# 로컬에서 생성: node scripts/print-vercel-service-account.mjs
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# 또는 3개 분리 (private_key는 JSON에서 복사한 \n 포함 문자열 그대로)
# FIREBASE_PROJECT_ID=vimeoportfolio-654c7
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@....iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 선택: Firestore admins 대신 이메일로 어드민 허용 (쉼표 구분)
# ADMIN_EMAILS=admin@example.com
