# Firebase Client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Admin (server-only)
# Option A: JSON file path (recommended for local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option B: full service account JSON as one line
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Option C: individual fields
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin (optional bootstrap — comma-separated emails)
ADMIN_EMAILS=admin@studio.com

# Site
NEXT_PUBLIC_SITE_NAME=MAKMALLO
NEXT_PUBLIC_SHOWREEL_VIMEO_ID=76979871

# Contact (placeholders — replace with real values)
NEXT_PUBLIC_CONTACT_EMAIL=hello@studio.com
NEXT_PUBLIC_CONTACT_PHONE=+1 (000) 000-0000
NEXT_PUBLIC_CONTACT_INSTAGRAM=https://instagram.com/studio
